<?xml version="1.0" encoding="utf-8"?>
<!-- Splash icon is masked to a circle; keep the mark inside the inscribed circle via large insets. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <size android:width="288dp" android:height="288dp" />
            <solid android:color="@color/ic_launcher_bg_veridid" />
        </shape>
    </item>
    <item
        android:left="92dp"
        android:top="92dp"
        android:right="92dp"
        android:bottom="92dp"
        android:drawable="@drawable/ic_veridid_mark_vector" />
</layer-list>
